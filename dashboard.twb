      <column caption='PY Orders' datatype='string' name='[Calculation_0332667957854211]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([Order Date])= [Parameters].[Parameter 1]  -1 THEN [Order ID]&#13;&#10;END' />
      </column>
      <column caption='Order Frequency' datatype='integer' name='[Calculation_0332667963252740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer Name] : COUNTD([Order ID]) }' />
      </column>
      <column caption='CY Sales' datatype='real' default-format='c&quot;$&quot;#,##0,K;&quot;$&quot;-#,##0,K' name='[Calculation_1105899109740544]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN[Sales]&#13;&#10;END' />
      </column>
      <column caption='PY Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_1105899110297601]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF      YEAR([Order Date]) = [Parameters].[Parameter 1] - 1 then [Sales]&#13;&#10;END' />
      </column>
      <column caption='Order Date (Years)' datatype='integer' name='[Calculation_1105899110572034]' role='measure' type='quantitative'>
