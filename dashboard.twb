      </column>
      <column caption='% Diff Sales' datatype='real' datatype-customized='true' default-format='p0.0%' name='[Calculation_1105899112505347]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='((SUM([Calculation_1105899109740544]) - SUM([Calculation_1105899110297601])) / SUM([Calculation_1105899110297601]))' />
      </column>
      <column caption='Min/Max Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_1213926170394624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if SUM([Calculation_1105899109740544])= WINDOW_MAX(SUM([Calculation_1105899109740544]))&#13;&#10;THEN SUM([Calculation_1105899109740544])&#13;&#10;ELSEIF SUM([Calculation_1105899109740544]) = WINDOW_MIN(SUM([Calculation_1105899109740544]))&#13;&#10;THEN SUM([Calculation_1105899109740544])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
