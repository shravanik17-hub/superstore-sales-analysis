      <column caption='CY Orders' datatype='string' name='[Calculation_0332667956523009]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Order ID]&#13;&#10;end' />
